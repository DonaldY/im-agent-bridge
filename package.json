{
  "name": "im-agent-bridge",
  "version": "0.1.1",
  "description": "DingTalk Stream Mode bridge for local agent CLIs",
  "type": "module",
  "bin": {
    "im-agent-bridge": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test --test-concurrency=1 test/*.test.ts",
    "doctor": "tsx src/cli.ts doctor",
    "start": "tsx src/cli.ts serve"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "dingtalk-stream-sdk-nodejs": "2.0.4",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3"
  }
}
